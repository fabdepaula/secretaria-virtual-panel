# Copie para .env e preencha (não commite .env).

# Supabase — públicas (também usadas no build da imagem Docker)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Servidor apenas (API routes) — nunca no browser
SUPABASE_SERVICE_ROLE_KEY=

# Opcional — webhook n8n para embeddings (há fallback no código se vazio)
N8N_EMBEDDING_WEBHOOK_URL=

# Opcional — porta publicada no host (docker compose)
# PANEL_PORT=3000
